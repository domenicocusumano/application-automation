# ── Secrets and credentials ──────────────────────────────────────────────────
.env
google_credentials.json
oauth_credentials.json
gdrive_token.json
linkedin_session.json

# ── Personal config (copy config.example.json → config.json and fill in) ────
config.json

# ── Personal background prompt (copy background_prompt.example.txt → background_prompt.txt) ──
background_prompt.txt

# ── Personal resume files ────────────────────────────────────────────────────
# base_resume/ holds your source resume — the folder is tracked, the file is not
base_resume/*.docx
base_resume/*.pdf
# resumes/ holds pipeline-generated tailored resumes — never commit these
resumes/

# ── Runtime output ───────────────────────────────────────────────────────────
pipeline_output.json

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
